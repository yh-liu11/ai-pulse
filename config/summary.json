{
  "llm": {
    "provider": "deepseek",
    "api_key_env": "DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com/chat/completions",
    "model": "deepseek-v4-pro",
    "x_model": "deepseek-v4-flash",
    "podcast_model": "deepseek-v4-pro",
    "paper_model": "deepseek-v4-pro",
    "thinking": {
      "type": "disabled"
    },
    "temperature": 0.2,
    "max_tokens": 4096,
    "timeout_seconds": 120,
    "x_timeout_seconds": 45,
    "podcast_timeout_seconds": 180,
    "paper_timeout_seconds": 90
  },
  "x_llm": {
    "provider": "ark",
    "api_key_env": "ARK_API_KEY",
    "base_url": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
    "model": "doubao-seed-2-1-pro-260628",
    "temperature": 0.2,
    "max_tokens": 2048,
    "timeout_seconds": 120
  },
  "papers_llm": {
    "provider": "ark",
    "api_key_env": "ARK_API_KEY",
    "base_url": "https://ark.cn-beijing.volces.com/api/v3/chat/completions",
    "model": "doubao-seed-2-1-pro-260628",
    "temperature": 0.2,
    "max_tokens": 512,
    "timeout_seconds": 45
  },
  "output": {
    "dir": "content/summaries",
    "index_path": "feeds/feed-summaries.json"
  },
  "default_profiles": [
    "zh_standard",
    "zh_deep",
    "en_standard"
  ],
  "profiles": {
    "zh_short": {
      "language": "zh",
      "detail": "short",
      "target_chars": 600,
      "podcast_target_chars": 800,
      "paper_target_chars": 300,
      "x_target_chars": 120,
      "include_x": true,
      "include_podcasts": true,
      "include_papers": false,
      "domains": [
        "ai",
        "invest"
      ]
    },
    "zh_standard": {
      "language": "zh",
      "detail": "standard",
      "target_chars": 1600,
      "podcast_target_chars": 2000,
      "paper_target_chars": 180,
      "x_target_chars": 160,
      "include_x": true,
      "include_podcasts": true,
      "include_papers": true,
      "domains": [
        "ai",
        "invest"
      ]
    },
    "zh_deep": {
      "language": "zh",
      "detail": "deep",
      "target_chars": 3000,
      "podcast_target_chars": 4500,
      "paper_target_chars": 220,
      "x_target_chars": 180,
      "include_x": true,
      "include_podcasts": true,
      "include_papers": true,
      "domains": [
        "ai",
        "invest"
      ]
    },
    "en_standard": {
      "language": "en",
      "detail": "standard",
      "target_chars": 1200,
      "podcast_target_chars": 1600,
      "paper_target_chars": 500,
      "x_target_chars": 180,
      "include_x": true,
      "include_podcasts": true,
      "include_papers": true,
      "domains": [
        "ai",
        "invest"
      ]
    },
    "bilingual_short": {
      "language": "bilingual",
      "detail": "short",
      "target_chars": 1000,
      "podcast_target_chars": 1200,
      "paper_target_chars": 400,
      "x_target_chars": 220,
      "include_x": true,
      "include_podcasts": true,
      "include_papers": false,
      "domains": [
        "ai"
      ]
    }
  },
  "podcasts": {
    "enabled": true,
    "input_path": "feeds/feed-podcasts.json",
    "max_input_chars": 60000,
    "fallback_to_description": true,
    "skip_without_text": true
  },
  "x": {
    "enabled": true,
    "input_path": "feeds/feed-x.json",
    "max_tweets": 1000
  },
  "papers": {
    "enabled": true,
    "input_path": "feeds/feed-arxiv.json",
    "max_items": 30
  }
}
